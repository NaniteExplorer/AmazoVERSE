# Copy this file to config.env and fill in real values.
# config.env is gitignored and must never be committed.
#
# In production (Vercel/Render), set these as platform env vars instead of a
# file, and set NODE_ENV=PRODUCTION.

PORT=4000

DB_URI=your-mongodb-connection-string

# Optional. Only needed if your local/host DNS refuses SRV lookups and a
# mongodb+srv:// URI fails with "querySrv ECONNREFUSED". Defaults to 8.8.8.8,1.1.1.1.
# DNS_SERVERS=8.8.8.8,1.1.1.1

JWT_SECRET=change-me
JWT_EXPIRE=5d
COOKIE_EXPIRE=5

CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMPT_HOST=
SMPT_PORT=
SMPT_SERVICE=
SMPT_MAIL=
SMPT_PASSWORD=

STRIPE_API_KEY=
STRIPE_SECRET_KEY=
